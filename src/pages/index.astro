---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="container">
      <div class="terminal-window">
        <div class="terminal-bar">
          <span class="dot red"></span>
          <span class="dot amber"></span>
          <span class="dot green"></span>
          <span class="terminal-title">bash — 80×24</span>
        </div>
        <div class="terminal-body">
          <div class="line"><span class="ps">guest@portfolio</span><span class="sep">:</span><span class="path">~</span><span class="dollar">$</span> <span class="cmd">whoami</span></div>
          <div class="line output name-output">Alex Rivera</div>
          <div class="line mt"><span class="ps">guest@portfolio</span><span class="sep">:</span><span class="path">~</span><span class="dollar">$</span> <span class="cmd">cat about.txt</span></div>
          <div class="line output about-block">
            <p>Backend Engineer &amp; DevOps Architect</p>
            <p>Building resilient infrastructure and scalable systems.</p>
            <p>5+ years shipping production services at scale.</p>
          </div>
          <div class="line mt"><span class="ps">guest@portfolio</span><span class="sep">:</span><span class="path">~</span><span class="dollar">$</span> <span class="cmd">cat stack.txt</span></div>
          <div class="line output stack-line">
            <span class="tag green">Go</span>
            <span class="tag green">Python</span>
            <span class="tag cyan">Kubernetes</span>
            <span class="tag cyan">Docker</span>
            <span class="tag cyan">Terraform</span>
            <span class="tag amber">AWS</span>
            <span class="tag amber">GCP</span>
            <span class="tag">PostgreSQL</span>
            <span class="tag">Redis</span>
          </div>
          <div class="line mt"><span class="ps">guest@portfolio</span><span class="sep">:</span><span class="path">~</span><span class="dollar">$</span> <span class="cmd blink-cursor">▋</span></div>
        </div>
      </div>

      <div class="cta-row">
        <a href="/projects" class="btn btn-primary">
          <span>$ ls ./projects</span>
        </a>
        <a href="/contact" class="btn btn-ghost">
          <span>$ send --message</span>
        </a>
        <a href="/experience" class="btn btn-ghost">
          <span>$ cat resume.txt</span>
        </a>
      </div>

      <div class="stats-row">
        <div class="stat">
          <span class="stat-val">5+</span>
          <span class="stat-label">years experience</span>
        </div>
        <div class="stat-sep">//</div>
        <div class="stat">
          <span class="stat-val">20+</span>
          <span class="stat-label">production systems</span>
        </div>
        <div class="stat-sep">//</div>
        <div class="stat">
          <span class="stat-val">99.9%</span>
          <span class="stat-label">uptime SLA</span>
        </div>
        <div class="stat-sep">//</div>
        <div class="stat">
          <span class="stat-val">∞</span>
          <span class="stat-label">coffee consumed</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.hero {
  min-height: calc(100vh - 60px);
  display: flex;
  align-items: center;
  padding: 4rem 0;
}

.terminal-window {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 3rem;
  box-shadow: 0 0 60px rgba(74,222,128,0.04), 0 20px 40px rgba(0,0,0,0.4);
}

.terminal-bar {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--bg-surface);
  padding: 10px 16px;
  border-bottom: 1px solid var(--border);
}
.dot {
  width: 12px; height: 12px;
  border-radius: 50%;
}
.dot.red { background: #ff5f57; }
.dot.amber { background: #febc2e; }
.dot.green { background: #28c840; }
.terminal-title {
  flex: 1;
  text-align: center;
  font-size: 11px;
  color: var(--text-dim);
  letter-spacing: 0.05em;
  margin-left: -52px;
}

.terminal-body {
  padding: 1.5rem 2rem 2rem;
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 1.8;
}

.line { display: flex; align-items: baseline; flex-wrap: wrap; gap: 0.35em; }
.line.mt { margin-top: 1rem; }
.ps { color: var(--green); font-weight: 600; }
.sep { color: var(--text-dim); }
.path { color: var(--cyan); }
.dollar { color: var(--text-dim); }
.cmd { color: var(--text-bright); }

.output { color: var(--text); padding-left: 0; margin-top: 2px; }
.output p { color: var(--text); }
.output p:first-child { color: var(--text-bright); font-weight: 600; font-size: 15px; font-family: var(--font-display); }

.about-block {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.stack-line { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }

.name-output {
  font-size: 22px;
  font-family: var(--font-display);
  font-weight: 800;
  color: var(--text-bright) !important;
  background: linear-gradient(90deg, var(--text-bright), var(--green));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

@keyframes blink-cur {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}
.blink-cursor {
  color: var(--green);
  animation: blink-cur 1s step-end infinite;
}

.cta-row {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

.btn {
  font-family: var(--font-mono);
  font-size: 12px;
  padding: 10px 20px;
  border-radius: 4px;
  border: 1px solid var(--border-bright);
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
}
.btn-primary {
  background: var(--green-glow);
  border-color: var(--green);
  color: var(--green);
}
.btn-primary:hover {
  background: rgba(74,222,128,0.25);
  color: var(--green);
  box-shadow: 0 0 20px rgba(74,222,128,0.2);
}
.btn-ghost { color: var(--text-dim); }
.btn-ghost:hover {
  color: var(--cyan);
  border-color: var(--cyan);
  background: rgba(34,211,238,0.05);
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.stat { display: flex; flex-direction: column; gap: 2px; }
.stat-val {
  font-size: 22px;
  font-weight: 700;
  font-family: var(--font-display);
  color: var(--green);
}
.stat-label {
  font-size: 11px;
  color: var(--text-dim);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.stat-sep {
  color: var(--border-bright);
  font-size: 18px;
}
</style>
