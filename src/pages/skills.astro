---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    label: "Languages",
    icon: "{}",
    color: "green",
    skills: [
      { name: "Go", level: 95 },
      { name: "Python", level: 90 },
      { name: "Bash/Shell", level: 88 },
      { name: "TypeScript", level: 70 },
      { name: "Rust", level: 50 },
    ]
  },
  {
    label: "Infrastructure",
    icon: "⬡",
    color: "cyan",
    skills: [
      { name: "Kubernetes", level: 92 },
      { name: "Docker", level: 95 },
      { name: "Terraform", level: 88 },
      { name: "Helm", level: 82 },
      { name: "Ansible", level: 78 },
    ]
  },
  {
    label: "Cloud Platforms",
    icon: "☁",
    color: "amber",
    skills: [
      { name: "AWS (EC2/ECS/Lambda)", level: 90 },
      { name: "GCP (GKE/Cloud Run)", level: 80 },
      { name: "Cloudflare", level: 75 },
      { name: "Azure (basics)", level: 55 },
    ]
  },
  {
    label: "Observability",
    icon: "◎",
    color: "cyan",
    skills: [
      { name: "Prometheus + Grafana", level: 90 },
      { name: "OpenTelemetry", level: 82 },
      { name: "Loki / ELK Stack", level: 80 },
      { name: "Datadog", level: 72 },
    ]
  },
  {
    label: "Databases & Messaging",
    icon: "▤",
    color: "green",
    skills: [
      { name: "PostgreSQL", level: 88 },
      { name: "Redis", level: 85 },
      { name: "Kafka", level: 78 },
      { name: "MongoDB", level: 70 },
      { name: "ClickHouse", level: 65 },
    ]
  },
  {
    label: "CI/CD & Security",
    icon: "⟳",
    color: "amber",
    skills: [
      { name: "GitHub Actions", level: 92 },
      { name: "ArgoCD", level: 85 },
      { name: "GitLab CI", level: 80 },
      { name: "Vault (HashiCorp)", level: 75 },
      { name: "Trivy / Snyk", level: 70 },
    ]
  },
];
---

<BaseLayout title="Skills">
  <section class="skills-page">
    <div class="container">
      <div class="page-header">
        <div class="prompt-line">
          <span class="ps1">guest@portfolio</span>
          <span style="color:var(--text-dim)">:</span>
          <span class="path">~/skills</span>
          <span style="color:var(--text-dim)">$</span>
          <span class="cmd">cat stack.json | jq .</span>
        </div>
        <h1 class="page-title">Tech Stack</h1>
        <p class="page-desc">Tools and technologies I work with daily in production environments.</p>
      </div>

      <div class="skills-grid">
        {categories.map(cat => (
          <div class={`skill-card border-${cat.color}`}>
            <div class="skill-card-header">
              <span class={`card-icon ${cat.color}`}>{cat.icon}</span>
              <h3 class="card-title">{cat.label}</h3>
            </div>
            <div class="skill-list">
              {cat.skills.map(skill => (
                <div class="skill-item">
                  <div class="skill-top">
                    <span class="skill-name">{skill.name}</span>
                    <span class={`skill-pct ${cat.color}`}>{skill.level}%</span>
                  </div>
                  <div class="bar-track">
                    <div class={`bar-fill ${cat.color}`} style={`width: ${skill.level}%`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="cert-section">
        <div class="prompt-line" style="margin-bottom:1.5rem">
          <span class="ps1">guest@portfolio</span>
          <span style="color:var(--text-dim)">:</span>
          <span class="path">~/skills</span>
          <span style="color:var(--text-dim)">$</span>
          <span class="cmd">ls ./certifications/</span>
        </div>
        <div class="cert-list">
          <div class="cert-item">
            <span class="cert-icon green">✓</span>
            <div>
              <div class="cert-name">AWS Solutions Architect – Professional</div>
              <div class="cert-meta">Amazon Web Services · 2023</div>
            </div>
          </div>
          <div class="cert-item">
            <span class="cert-icon cyan">✓</span>
            <div>
              <div class="cert-name">Certified Kubernetes Administrator (CKA)</div>
              <div class="cert-meta">Cloud Native Computing Foundation · 2022</div>
            </div>
          </div>
          <div class="cert-item">
            <span class="cert-icon amber">✓</span>
            <div>
              <div class="cert-name">HashiCorp Certified: Terraform Associate</div>
              <div class="cert-meta">HashiCorp · 2022</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.skills-page { padding: 4rem 0 2rem; }

.page-header { margin-bottom: 3rem; }
.page-title {
  font-size: clamp(28px, 5vw, 42px);
  font-weight: 800;
  margin: 0.5rem 0;
}
.page-desc { color: var(--text-dim); font-size: 13px; }

.ps1 { color: var(--green); font-family: var(--font-mono); font-size: 12px; }
.path { color: var(--cyan); font-family: var(--font-mono); font-size: 12px; }
.cmd { color: var(--text-bright); font-family: var(--font-mono); font-size: 12px; }

.skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
  margin-bottom: 4rem;
}

.skill-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 1.5rem;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.skill-card:hover { box-shadow: 0 0 30px rgba(74,222,128,0.05); }
.skill-card.border-green:hover { border-color: rgba(74,222,128,0.3); }
.skill-card.border-cyan:hover { border-color: rgba(34,211,238,0.3); }
.skill-card.border-amber:hover { border-color: rgba(251,191,36,0.3); }

.skill-card-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.25rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border);
}
.card-icon { font-size: 16px; }
.card-icon.green { color: var(--green); }
.card-icon.cyan { color: var(--cyan); }
.card-icon.amber { color: var(--amber); }
.card-title { font-size: 14px; font-weight: 600; color: var(--text-bright); font-family: var(--font-mono); }

.skill-list { display: flex; flex-direction: column; gap: 0.85rem; }
.skill-item {}
.skill-top { display: flex; justify-content: space-between; margin-bottom: 5px; }
.skill-name { font-size: 12px; color: var(--text); }
.skill-pct { font-size: 11px; font-weight: 600; }
.skill-pct.green { color: var(--green); }
.skill-pct.cyan { color: var(--cyan); }
.skill-pct.amber { color: var(--amber); }

.bar-track {
  height: 3px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 1s ease;
}
.bar-fill.green { background: linear-gradient(90deg, var(--green-dim), var(--green)); }
.bar-fill.cyan { background: linear-gradient(90deg, var(--cyan-dim), var(--cyan)); }
.bar-fill.amber { background: linear-gradient(90deg, #d97706, var(--amber)); }

.cert-section {
  border-top: 1px solid var(--border);
  padding-top: 3rem;
}
.cert-list { display: flex; flex-direction: column; gap: 1rem; }
.cert-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1rem 1.25rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 6px;
}
.cert-icon { font-size: 16px; margin-top: 2px; }
.cert-icon.green { color: var(--green); }
.cert-icon.cyan { color: var(--cyan); }
.cert-icon.amber { color: var(--amber); }
.cert-name { font-size: 13px; color: var(--text-bright); margin-bottom: 3px; }
.cert-meta { font-size: 11px; color: var(--text-dim); }
</style>
