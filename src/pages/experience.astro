---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  {
    company: "Wellnest",
    role: "Full Stack Engineer",
    period: "Sep 2025 — Mar 2026",
    location: "Trivandrum, Kerala",
    color: "green",
    current: false,
    points: [
     "Architected high-throughput RESTful services using Go (Gin) and Clean Architecture, significantly reducing technical debt and accelerating feature delivery cycles.",
     "Engineered a scalable multi-service backend for health-data processing, utilizing GORM-optimized PostgreSQL schemas and indexing to enhance overall query performance.",
     "Orchestrated robust production workloads on AWS (EC2, RDS, DynamoDB), configuring automated backup policies and Elastic IP routing to ensure high system availability.",
     "Streamlined release workflows by developing GitHub Actions CI/CD pipelines, eliminating manual deployment bottlenecks and ensuring strict build consistency.",
     "Hardened infrastructure security and optimized traffic distribution via Nginx reverse proxy configurations, successfully reducing end-to-end system latency.",
     "Implemented comprehensive JWT-based RBAC (Role-Based Access Control), strictly securing sensitive endpoints across health and user management modules.",
     "Developed a centralized admin ecosystem using Vue.js, integrating backend APIs to provide stakeholders with reliable data visualization and system oversight."
    ]
  },
  {
    company: "Enfin Technologies",
    role: "Junior Software Engineer",
    period: "Jan 2023 — Apr 2023",
    location: "Trivandrum, Kerala",
    color: "cyan",
    current: false,
    points: [
      "Engineered scalable RESTful APIs using Node.js and Express with modular architecture patterns  .",
      "Architected NoSQL schemas in MongoDB optimized for high-concurrency data operations.",
      "Orchestrated full-stack integration between React interfaces and complex server-side logic.",
      "Hardened API security through standardized middleware for authentication and request validation.",
    ]
  }
];

const education = {
  degree: "B.Tech Computer Science",
  school: "APJ Abdul Kalam Technological University",
  year: "2016— 2020"
  

};
---

<BaseLayout title="Experience">
  <section class="exp-page">
    <div class="container">
      <div class="page-header">
        <div class="prompt-line">
          <span class="ps1">guest@portfolio</span>
          <span style="color:var(--text-dim)">:</span>
          <span class="path">~/experience</span>
          <span style="color:var(--text-dim)">$</span>
          <span class="cmd">cat resume.txt</span>
        </div>
        <h1 class="page-title">Experience</h1>
        <p class="page-desc">1+ years building and operating production systems at scale.</p>
      </div>

      <div class="timeline">
        {experience.map((job, i) => (
          <div class={`timeline-item color-${job.color}`}>
            <div class="timeline-connector">
              <div class={`timeline-dot ${job.color}`}>{job.current ? '◉' : '○'}</div>
              {i < experience.length - 1 && <div class="timeline-line"></div>}
            </div>
            <div class="timeline-content">
              <div class="job-header">
                <div>
                  <h3 class="job-role">{job.role}</h3>
                  <div class="job-company">
                    <span class={job.color}>{job.company}</span>
                    <span class="job-location">· {job.location}</span>
                  </div>
                </div>
                <div class="job-period-wrap">
                  <span class="job-period">{job.period}</span>
                  {job.current && <span class="current-badge">CURRENT</span>}
                </div>
              </div>
              <ul class="job-points">
                {job.points.map(p => (
                  <li>
                    <span class={`bullet ${job.color}`}>▸</span>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <div class="edu-section">
        <div class="prompt-line" style="margin-bottom:1.25rem">
          <span class="ps1">guest@portfolio</span>
          <span style="color:var(--text-dim)">:</span>
          <span class="path">~/experience</span>
          <span style="color:var(--text-dim)">$</span>
          <span class="cmd">cat education.txt</span>
        </div>
        <div class="edu-card">
          <div class="edu-icon">🎓</div>
          <div>
            <div class="edu-degree">{education.degree}</div>
            <div class="edu-school">{education.school}</div>
            <div class="edu-meta">{education.year}</div>
          </div>
        </div>
      </div>

      <div class="download-row">
        <a href="#" class="btn-download">
          <span>↓ download resume.pdf</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.exp-page { padding: 4rem 0 2rem; }
.page-header { margin-bottom: 3rem; }
.page-title { font-size: clamp(28px, 5vw, 42px); font-weight: 800; margin: 0.5rem 0; }
.page-desc { color: var(--text-dim); font-size: 13px; }
.ps1 { color: var(--green); font-family: var(--font-mono); font-size: 12px; }
.path { color: var(--cyan); font-family: var(--font-mono); font-size: 12px; }
.cmd { color: var(--text-bright); font-family: var(--font-mono); font-size: 12px; }

.timeline { display: flex; flex-direction: column; gap: 0; margin-bottom: 4rem; }

.timeline-item {
  display: grid;
  grid-template-columns: 40px 1fr;
  gap: 1.5rem;
}

.timeline-connector {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.timeline-dot {
  font-size: 14px;
  padding: 6px 0;
  line-height: 1;
}
.timeline-dot.green { color: var(--green); }
.timeline-dot.cyan { color: var(--cyan); }
.timeline-dot.amber { color: var(--amber); }
.timeline-line {
  flex: 1;
  width: 1px;
  background: var(--border);
  margin: 4px 0;
  min-height: 30px;
}

.timeline-content {
  padding-bottom: 3rem;
}

.job-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1rem;
}
.job-role {
  font-size: 17px;
  font-weight: 700;
  color: var(--text-bright);
  margin-bottom: 3px;
}
.job-company { font-size: 13px; font-family: var(--font-mono); }
.job-company .green { color: var(--green); }
.job-company .cyan { color: var(--cyan); }
.job-company .amber { color: var(--amber); }
.job-location { color: var(--text-dim); }

.job-period-wrap { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
.job-period { font-size: 11px; color: var(--text-dim); font-family: var(--font-mono); white-space: nowrap; }
.current-badge {
  font-size: 9px;
  letter-spacing: 0.1em;
  color: var(--green);
  border: 1px solid var(--green);
  padding: 2px 6px;
  border-radius: 2px;
}

.job-points {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.job-points li {
  display: flex;
  gap: 0.6rem;
  font-size: 12px;
  color: var(--text);
  line-height: 1.6;
}
.bullet { font-size: 10px; margin-top: 3px; flex-shrink: 0; }
.bullet.green { color: var(--green); }
.bullet.cyan { color: var(--cyan); }
.bullet.amber { color: var(--amber); }

.edu-section {
  border-top: 1px solid var(--border);
  padding-top: 3rem;
  margin-bottom: 3rem;
}
.edu-card {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 1.25rem 1.5rem;
}
.edu-icon { font-size: 28px; }
.edu-degree { font-size: 15px; color: var(--text-bright); font-weight: 600; margin-bottom: 3px; }
.edu-school { font-size: 13px; color: var(--cyan); font-family: var(--font-mono); margin-bottom: 3px; }
.edu-meta { font-size: 11px; color: var(--text-dim); font-family: var(--font-mono); }

.download-row { display: flex; }
.btn-download {
  font-family: var(--font-mono);
  font-size: 12px;
  padding: 10px 20px;
  border: 1px solid var(--border-bright);
  border-radius: 4px;
  color: var(--text-dim);
  transition: all 0.2s;
}
.btn-download:hover {
  color: var(--green);
  border-color: var(--green);
  background: rgba(74,222,128,0.05);
}
</style>
